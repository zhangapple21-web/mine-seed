# ACE Runtime — 0 依赖 crontab v2.0
# 全部使用免费 API 直连，不依赖 TRAE 额度
# 用法: crontab /workspace/fengzi-repos/mine-seed/06_RUNTIME/crontab.ace
# 时区: Asia/Shanghai (UTC+8)

SHELL=/bin/bash
PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin
HOME=/root

# === 存活自检（每小时）===
0 * * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh liveness >> /tmp/mine_output/cron_liveness.log 2>&1

# === 矿场班次（每4小时，GLM+NIM+GitHub混用）===
0 */4 * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh miner >> /tmp/mine_output/cron_miner.log 2>&1

# === 信号发现（每6小时，GLM）===
30 2,8,14,20 * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh signals >> /tmp/mine_output/cron_signals.log 2>&1

# === 每日荐股（工作日08:15，GLM）===
15 8 * * 1-5 bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh advisor >> /tmp/mine_output/cron_advisor.log 2>&1

# === 知识早班（每天05:00，GLM）===
0 5 * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh research_morning >> /tmp/mine_output/cron_research.log 2>&1

# === 知识午班（每天12:00，GLM）===
0 12 * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh research_noon >> /tmp/mine_output/cron_research.log 2>&1

# === 档案官归档（每天20:04，无API）===
4 20 * * * bash /workspace/fengzi-repos/mine-seed/05_TOOLS/miner/run_free_task.sh archivist >> /tmp/mine_output/cron_archivist.log 2>&1

# === 文明日报（每天04:00，free_llm）===
0 4 * * * cd /workspace/fengzi-repos/mine-seed/05_TOOLS/miner && source free_api.env && python3 civilization_daily.py >> /tmp/mine_output/cron_civilizer.log 2>&1
